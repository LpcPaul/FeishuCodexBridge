# Required: create a Feishu/Lark custom app with bot capability first.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret

# Optional runtime settings.
# FEISHU_CODEX_WORKDIR defaults to your home directory.
FEISHU_CODEX_WORKDIR=

# Optional: installer tries to auto-detect these.
PYTHON_BIN=
NODE_BIN=
CODEX_BIN=

# Optional context/topic settings.
FEISHU_TOPIC_IDLE_SECONDS=7200
FEISHU_TOPIC_NOTICE_ENABLED=1
FEISHU_TOPIC_NOTICE_POLL_SECONDS=60
FEISHU_TASK_PROGRESS_SECONDS=7200
FEISHU_ACK_TEXT=收到，我要开始干活了，稍等我

# Optional: reply to non-@ messages in one-human small groups.
# Requires Feishu to deliver all group messages and allow member lookup.
FEISHU_GROUP_AUTO_REPLY_ENABLED=1
FEISHU_GROUP_AUTO_REPLY_MAX_HUMAN_MEMBERS=1
FEISHU_GROUP_AUTO_REPLY_CHAT_IDS=
FEISHU_GROUP_MEMBER_CACHE_SECONDS=600

# Optional: Codex-generated Feishu cards.
FEISHU_CODEX_CARDS_ENABLED=1
# Set to 1 when you want to send CardKit 2.0 cards by card_id.
# Requires CardKit card create permission in the Feishu app.
FEISHU_CARDKIT_ENABLED=0

# Optional: Codex-generated Feishu docs.
# Requires the app to have new-doc create/edit permissions.
FEISHU_DOCS_ENABLED=0
# Optional target folder token. Leave empty to use the app's default location.
FEISHU_DOCS_FOLDER_TOKEN=
FEISHU_DOCS_DOMAIN=https://feishu.cn
FEISHU_DOCS_AUTO_MIN_CHARS=4500
FEISHU_DOCS_BLOCK_CHARS=1500
